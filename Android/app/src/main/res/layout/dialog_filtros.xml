<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <Spinner
        android:id="@+id/spFiltroGenero"
        android:layout_width="match_parent"
        android:entries="@array/generos_filtro_array"
        android:layout_height="56dp" />

    <Spinner
        android:id="@+id/spFiltroEstado"
        android:layout_width="match_parent"
        android:entries="@array/estados_filtro_array"
        android:layout_height="56dp"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/etFiltroValoracion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/valoracion_minima"
        android:inputType="number"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/etFiltroTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/buscar_titulo"
        android:inputType="text"
        android:layout_marginTop="12dp" />

</LinearLayout>