<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/informacion_contenido"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/titulo"
            android:inputType="text"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <Spinner
            android:id="@+id/spGenero"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:entries="@array/generos_array"
            android:background="@android:drawable/editbox_background"
            android:padding="16dp" />

        <EditText
            android:id="@+id/etValoracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/valoracion_1_5"
            android:inputType="number"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <Spinner
            android:id="@+id/spEstado"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:entries="@array/estados_array"
            android:background="@android:drawable/editbox_background"
            android:padding="16dp" />

        <EditText
            android:id="@+id/etDescripcion"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:hint="@string/descripcion_completa_hint"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etImagenUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/url_imagen"
            android:inputType="textUri"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="30dp"
            android:text="@string/guardar_cambios"
            app:backgroundTint="#6200EA"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>