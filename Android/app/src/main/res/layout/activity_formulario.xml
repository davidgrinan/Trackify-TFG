<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Información del Contenido"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título"
            android:inputType="text"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Género (Ej: Acción)"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etValoracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Valoración (1-5)"
            android:inputType="number"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Estado (Ej: Pendiente, Visto)"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etDescripcion"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:hint="Descripción completa..."
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <EditText
            android:id="@+id/etImagenUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL de la imagen"
            android:inputType="textUri"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="@android:drawable/editbox_background"/>

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="30dp"
            android:text="GUARDAR CAMBIOS"
            app:backgroundTint="#6200EA"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>